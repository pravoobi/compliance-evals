{
  "name": "@compliance-evals/core",
  "version": "0.1.0",
  "description": "Compliance-native evaluation library for LLM applications",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@compliance-evals/types": "^0.1.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  }
}
