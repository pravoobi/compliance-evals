    "lint": "eslint src"
  },
  "dependencies": {
    "uuid": "^11.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^3.0.5"
  }
}
