{
  "name": "@compliance-evals/types",
  "version": "0.1.0",
  "description": "Shared data model for compliance-evals",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
